{
  "name": "magproj",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "app/*",
    "shared/*"
  ],
  "scripts": {
    "typecheck": "npm run typecheck --workspaces --if-present",
