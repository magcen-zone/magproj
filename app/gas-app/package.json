{
  "name": "gas-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc -p jsconfig.json --noEmit",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "build": "esbuild vendor-pack.js --bundle --format=iife --global-name=Vendor --target=es2020 --outfile=src/app/vendor.js",
    "dev": "npm run build -- --watch",
    "push": "clasp push",
    "deploy": "clasp deploy"
  },
  "dependencies": {
    "@app/core": "*"
  },
  "devDependencies": {
    "@google/clasp": "^3",
    "@jest/globals": "30.3.0",
    "@types/google-apps-script": "^1",
    "esbuild": "^0.25",
    "jest": "30.3.0",
    "typescript": "^5"
  }
}
